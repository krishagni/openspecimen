<?xml version='1.0' encoding='utf-8'?>
<!DOCTYPE hibernate-mapping PUBLIC
  "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
  "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping auto-import="false">
  <class name="com.krishagni.catissueplus.core.biospecimen.domain.RequestManagerGroup" table="OS_REQ_MGR_GROUPS"
    entity-name="com.krishagni.catissueplus.core.biospecimen.domain.RequestManagerGroup">

    <id name="id" column="IDENTIFIER">
      <generator class="native">
        <param name="sequence">OS_REQ_MGR_GROUPS_SEQ</param>
      </generator>
    </id>

    <property name="name" column="NAME"/>

    <many-to-one name="userGroup" column="USER_GROUP_ID"/>

    <set name="cps" table="CATISSUE_COLLECTION_PROTOCOL" inverse="true">
      <key column="RMG_ID"/>
      <one-to-many class="com.krishagni.catissueplus.core.biospecimen.domain.CollectionProtocol"/>
      <filter name="activeEntity" condition="activity_status != 'Disabled'"/>
    </set>

    <set name="cpgs" table="OS_CP_GROUPS" inverse="true">
      <key column="RMG_ID"/>
      <one-to-many class="com.krishagni.catissueplus.core.biospecimen.domain.CollectionProtocolGroup"/>
      <filter name="activeEntity" condition="activity_status != 'Disabled'"/>
    </set>

    <query name="getByName">
      select
        rmg
      from
        com.krishagni.catissueplus.core.biospecimen.domain.RequestManagerGroup rmg
      where
        rmg.name = :name
    </query>

    <sql-query name="getActiveCpCounts">
      <return-scalar column="rmg_id" type="long" />
      <return-scalar column="cp_count" type="long" />

      select
        cp.rmg_id as rmg_id, count(cp.identifier) as cp_count
      from
        catissue_collection_protocol cp
      where
        cp.rmg_id in (:groupIds) and
        cp.activity_status != 'Disabled'
      group by
        cp.rmg_id
    </sql-query>
  </class>
</hibernate-mapping>
