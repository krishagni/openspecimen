<table cellspacing="0" cellpadding="0" border="0" width="100%" style="border-spacing:0;border-collapse:separate">
  <tbody>
    <tr>
      <td style="border-collapse:collapse;">
        <table cellspacing="0" cellpadding="0" border="0" width="100%" style="border-collapse:collapse;font-family:Arial,sans-serif;font-size:14px;line-height:20px">
          <tbody>
            <tr>
              <td style="padding:0px;border-collapse:collapse;padding-bottom:10px">
                <p style="margin:10px 0 0 0">
                  Hello,
                  <br><br>
                  The OpenSpecimen setting <strong>$setting</strong> was changed by $changedByName.
                </p>
              </td>
            </tr>
            <tr>
              <td style="border-collapse:collapse;padding-bottom:10px">
                <table cellspacing="0" cellpadding="4" border="0" style="border-collapse:collapse;color:#333">
                  <tbody>
                    <tr>
                      <td style="font-weight:bold">Changed On</td>
                      <td>$changedOn</td>
                    </tr>
                    <tr>
                      <td style="font-weight:bold">New Value</td>
                      <td>$value</td>
                    </tr>
                  </tbody>
                </table>
              </td>
            </tr>
          </tbody>
        </table>
      </td>
    </tr>
    <tr>
      <td style="height:5px;line-height:5px;">&nbsp;</td>
    </tr>
    <tr>
      <td>
        #parse( $footer )
      </td>
    </tr>
  </tbody>
</table>
