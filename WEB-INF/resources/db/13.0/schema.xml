<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
  http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">

  <changeSet author="vpawar" id="OAuth states">
    <createTable tableName="OS_OAUTH_STATES">
      <column name="IDENTIFIER" type="${int.type}" autoIncrement="${autoIncrement}">
        <constraints nullable="false" primaryKey="true" />
      </column>
      <column name="STATE" type="${text.type}(255)">
        <constraints nullable="false" unique="true" uniqueConstraintName="OS_OAUTH_STATES_UQ"/>
      </column>
      <column name="DOMAIN_ID" type="${int.type}">
        <constraints nullable="false" foreignKeyName="FK_OAUTH_STATE_DOMAIN"
          referencedTableName="OS_AUTH_DOMAINS" referencedColumnNames="IDENTIFIER" />
      </column>
      <column name="VERIFIER" type="${text.type}(255)">
        <constraints nullable="false" />
      </column>
      <column name="CHALLENGE" type="${text.type}(255)">
        <constraints nullable="false" />
      </column>
      <column name="AUTH_TIME" type="${nullable.ts.type}">
        <constraints nullable="false" />
      </column>
    </createTable>
  </changeSet>

  <changeSet author="vpawar" id="OAuth state ID generator" dbms="oracle">
    <createSequence sequenceName="OS_OAUTH_STATES_SEQ" startValue="1" incrementBy="1" ordered="true" />
  </changeSet>

  <changeSet author="vpawar" id="Index on OAuth state time to facilitate faster clean up of old states">
    <createIndex tableName="OS_OAUTH_STATES" indexName="OS_OAUTH_STATE_TIME_IDX">
      <column name="AUTH_TIME" />
    </createIndex>
  </changeSet>

  <changeSet author="vpawar" id="CP Request managers">
    <addColumn tableName="CATISSUE_COLLECTION_PROTOCOL">
      <column name="REQ_MANAGERS_USER_GROUP_ID" type="${int.type}">
        <constraints foreignKeyName="FK_CP_REQ_MANAGERS_UG_IDX" referencedTableName="OS_USER_GROUPS"
          referencedColumnNames="IDENTIFIER" />
      </column>
    </addColumn>
  </changeSet>

  <changeSet author="vpawar" id="CP group ID in CP table">
    <addColumn tableName="CATISSUE_COLLECTION_PROTOCOL">
      <column name="CP_GROUP_ID" type="${int.type}">
        <constraints foreignKeyName="FK_CP_CP_GROUP_ID" referencedTableName="OS_CP_GROUPS"
          referencedColumnNames="IDENTIFIER" />
      </column>
    </addColumn>
  </changeSet>

  <changeSet author="vpawar" id="Index on CP group ID of CP table" dbms="oracle">
    <createIndex tableName="CATISSUE_COLLECTION_PROTOCOL" indexName="CP_CP_GROUP_ID_IDX">
      <column name="CP_GROUP_ID" />
    </createIndex>
  </changeSet>

  <changeSet author="vpawar" id="Migrate CP groups to CP table">
    <preConditions onFail="HALT">
      <sqlCheck expectedResult="0">
        <![CDATA[
          select count(*) from (select cp_id from os_cp_group_cps group by cp_id having count(*) > 1) t
        ]]>
      </sqlCheck>
    </preConditions>
    <sql>
      update
        catissue_collection_protocol cp
      set
        cp_group_id = (
          select
            g.group_id
          from
            os_cp_group_cps g
          where
            g.cp_id = cp.identifier
        )
      where
        exists (select 1 from os_cp_group_cps g where g.cp_id = cp.identifier)
    </sql>
  </changeSet>

  <changeSet author="vpawar" id="Drop CP group join table">
    <dropTable tableName="OS_CP_GROUP_CPS" cascadeConstraints="true" />
  </changeSet>

  <changeSet author="vpawar" id="Unique constraint on the container position" dbms="mysql">
    <addUniqueConstraint constraintName="OS_CONTAINER_POS_UQ"
      tableName="OS_CONTAINER_POSITIONS" columnNames="STORAGE_CONTAINER_ID,POS_ONE_STR,POS_TWO_STR"/>
  </changeSet>

  <changeSet author="vpawar" id="Unique constraint on the container position" dbms="oracle">
    <sql>
      create unique index
        OS_CONTAINER_POS_UQ
      on os_container_positions(
        case when
          pos_one_str is not null and pos_two_str is not null
        then
          storage_container_id || '-' || pos_one_str || '-' || pos_two_str
        end
      );
    </sql>
  </changeSet>

  <changeSet author="vpawar" id="CP group request managers">
    <addColumn tableName="OS_CP_GROUPS">
      <column name="REQ_MANAGERS_USER_GROUP_ID" type="${int.type}">
        <constraints foreignKeyName="FK_CPG_REQ_MANAGERS_UG_IDX" referencedTableName="OS_USER_GROUPS"
          referencedColumnNames="IDENTIFIER" />
      </column>
    </addColumn>
  </changeSet>

  <changeSet author="vpawar" id="Capacity in container types">
    <addColumn tableName="OS_CONTAINER_TYPES">
      <column name="CAPACITY" type="${int.type}" />
    </addColumn>
  </changeSet>

  <changeSet author="vpawar" id="Primary specimen ID">
    <addColumn tableName="CATISSUE_SPECIMEN">
      <column name="PRIMARY_SPECIMEN_ID" type="${int.type}">
        <constraints foreignKeyName="FK_PRIMARY_SPECIMEN_ID" referencedTableName="CATISSUE_SPECIMEN"
          referencedColumnNames="IDENTIFIER" />
      </column>
    </addColumn>
  </changeSet>

  <changeSet author="vpawar" id="Index on primary specimen ID">
    <createIndex tableName="CATISSUE_SPECIMEN" indexName="OS_PRIMARY_SPMN_IDX">
      <column name="PRIMARY_SPECIMEN_ID" />
    </createIndex>
  </changeSet>

  <changeSet author="vpawar" id="Specimen collection and received details">
    <createTable tableName="OS_SPMN_COLL_RECV_DETAILS">
      <column name="PRIMARY_SPECIMEN_ID" type="${int.type}">
        <constraints nullable="false" primaryKey="true" foreignKeyName="FK_SPMN_CRD_PRIMARY_SPMN"
          referencedTableName="CATISSUE_SPECIMEN" referencedColumnNames="IDENTIFIER" />
      </column>
      <column name="COLLECTION_CONTAINER_ID" type="${int.type}">
        <constraints foreignKeyName="FK_SPMN_CRD_COLL_CONT" referencedTableName="CATISSUE_PERMISSIBLE_VALUE"
          referencedColumnNames="IDENTIFIER" />
      </column>
      <column name="COLLECTION_PROCEDURE_ID" type="${int.type}">
        <constraints foreignKeyName="FK_SPMN_CRD_COLL_PROC" referencedTableName="CATISSUE_PERMISSIBLE_VALUE"
          referencedColumnNames="IDENTIFIER" />
      </column>
      <column name="COLLECTION_USER_ID" type="${int.type}">
        <constraints foreignKeyName="FK_SPMN_CRD_COLLECTOR" referencedTableName="CATISSUE_USER"
          referencedColumnNames="IDENTIFIER" />
      </column>
      <column name="COLLECTION_TIME" type="${nullable.ts.type}" defaultValue="null" />
      <column name="COLLECTION_COMMENTS" type="${text.type}(512)" />
      <column name="RECEIVED_QUALITY_ID" type="${int.type}">
        <constraints foreignKeyName="FK_SPMN_CRD_RECV_QUALITY" referencedTableName="CATISSUE_PERMISSIBLE_VALUE"
          referencedColumnNames="IDENTIFIER" />
      </column>
      <column name="RECEIVED_USER_ID" type="${int.type}">
        <constraints foreignKeyName="FK_SPMN_CRD_RECEIVER" referencedTableName="CATISSUE_USER"
          referencedColumnNames="IDENTIFIER" />
      </column>
      <column name="RECEIVED_TIME" type="${nullable.ts.type}" defaultValue="null" />
      <column name="RECEIVED_COMMENTS" type="${text.type}(512)" />
    </createTable>
  </changeSet>

  <changeSet author="vpawar" id="Drop specimen collection and received details view">
    <preConditions onFail="MARK_RAN">
      <viewExists viewName="OS_SPMN_COLL_RECV_DETAILS_VIEW"/>
    </preConditions>
    <dropView viewName="OS_SPMN_COLL_RECV_DETAILS_VIEW"/>
  </changeSet>
</databaseChangeLog>
